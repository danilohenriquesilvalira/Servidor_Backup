{
  "identifier": "default",
  "description": "Permissoes padrao para todas as plataformas",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [{ "url": "http://**" }, { "url": "https://**" }]
    },
    "notification:default",
    "store:default",
    "fs:default"
  ]
}
